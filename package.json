{
  "name": "quickeR",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync-version": "node -e \"const m=JSON.parse(require('fs').readFileSync('public/manifest.json','utf8'));m.version=require('./package.json').version;require('fs').writeFileSync('public/manifest.json',JSON.stringify(m,null,2)+'\\n')\"",
    "predev": "npm run sync-version",
    "dev": "vite",
    "prebuild": "npm run sync-version",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@owlbear-rodeo/sdk": "^2.0.0",
    "qrcode.react": "^3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "postcss": "^8.4.27",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.0.2",
    "vite": "^4.4.5"
  }
}
